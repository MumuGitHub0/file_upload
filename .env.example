# ================================
# 大文件上传下载服务配置文件
# ================================
# 复制此文件为 .env 并根据实际情况修改配置项

# ========== 存储配置 ==========
# 存储后端类型（local 或 oss）
STORAGE_BACKEND=local

# 本地存储路径（STORAGE_BACKEND=local 时生效）
LOCAL_STORAGE_PATH=./data/files
LOCAL_CHUNK_PATH=./data/chunks

# OSS 配置（STORAGE_BACKEND=oss 时必须填写）
# OSS_ENDPOINT=
# OSS_ACCESS_KEY_ID=
# OSS_ACCESS_KEY_SECRET=
# OSS_BUCKET_NAME=

# ========== 上传配置 ==========
# 分片大小（字节）- 建议范围: 1MB-50MB
CHUNK_SIZE=5242880
# 单个文件最大大小（字节）- 默认 1GB
MAX_FILE_SIZE=1073741824
# 允许的文件扩展名（逗号分隔，留空表示不限制）
# 示例: .jpg,.png,.mp4,.pdf
ALLOWED_EXTENSIONS=

# ========== 安全配置 ==========
# CORS 允许的来源（多个用逗号分隔，* 表示允许所有）
# 生产环境建议设置具体域名，如: https://example.com,https://api.example.com
CORS_ORIGINS=*
# 调试模式（true/false）- 生产环境请设置为 false
DEBUG=false

# ========== 服务器配置 ==========
# 服务监听地址（0.0.0.0 表示监听所有网卡）
HOST=0.0.0.0
# 服务监听端口
PORT=8000

# ========== 运维配置 ==========
# 日志级别（DEBUG, INFO, WARNING, ERROR）
LOG_LEVEL=INFO
# 数据库连接字符串（默认使用 SQLite）
# 如需使用其他数据库，可修改此配置，如：
# PostgreSQL: postgresql://user:password@localhost/dbname
# MySQL: mysql+pymysql://user:password@localhost/dbname
DATABASE_URL=

# ========== 清理配置 ==========
# 未完成上传任务过期时间（小时）- 默认 24 小时
UPLOAD_EXPIRE_HOURS=24
# 清理任务执行间隔（分钟）- 默认 60 分钟
CLEANUP_INTERVAL_MINUTES=60

# ========== 病毒扫描配置 ==========
# 是否启用病毒扫描（true/false）
VIRUS_SCAN_ENABLED=false
# 扫描引擎类型（clamav 或 api）
VIRUS_SCAN_ENGINE=clamav
# ClamAV socket 路径
CLAMAV_SOCKET=/var/run/clamav/clamd.ctl
# 外部扫描 API 地址（VIRUS_SCAN_ENGINE=api 时使用）
# VIRUS_SCAN_API_URL=

# ========== 文件过期配置 ==========
# 文件默认过期天数（0 表示永不过期）
FILE_DEFAULT_EXPIRE_DAYS=0

# ========== 回调通知配置 ==========
# 上传完成回调 URL（留空表示不发送回调）
# UPLOAD_CALLBACK_URL=
# 回调超时时间（秒）
UPLOAD_CALLBACK_TIMEOUT=30
# 回调重试次数
UPLOAD_CALLBACK_RETRIES=3

# ========== 预览配置 ==========
# 是否启用预览功能（true/false）
PREVIEW_ENABLED=true
# 支持预览的文件类型（逗号分隔）
PREVIEW_SUPPORTED_TYPES=.jpg,.jpeg,.png,.gif,.webp,.bmp,.mp4,.webm
# 缩略图尺寸
THUMBNAIL_SIZE=200x200